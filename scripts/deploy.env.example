# deploy.env.example — copy to scripts/deploy.env and fill in.
#
#   cp scripts/deploy.env.example scripts/deploy.env
#   $EDITOR scripts/deploy.env
#
# scripts/deploy.env is gitignored. deploy-bootstrap.sh sources it
# (if present) and threads the variables below into the hosted demo
# agent's systemd Environment= block on each bootstrap VPS.
#
# Without ANTHROPIC_API_KEY the demo agent still runs — it just uses
# the deterministic executor (no real LLM). Set the key to make
# `gyza submit "<task>"` return actual Claude-generated answers.

# Anthropic API key for the hosted demo agents' real-LLM executor.
ANTHROPIC_API_KEY=sk-ant-...

# Quota gates (all optional — sensible defaults applied if unset).
#
#   PER_SUBMITTER_QUERIES — real-LLM queries per submitter pubkey
#                           per UTC day before that submitter is
#                           rate-limited to the deterministic
#                           fallback. Default 10.
#   GLOBAL_QUERIES        — total real-LLM queries per agent per
#                           UTC day. Default 1000.
#   GLOBAL_SPEND_USD      — hard daily spend ceiling per agent,
#                           estimated from token counts at Claude
#                           Sonnet pricing. Default 5.00.
#
# A viral HN moment is bounded by GLOBAL_SPEND_USD × 3 agents.
# At $5/agent that's $15/day worst case. Raise deliberately.
GYZA_DEMO_PER_SUBMITTER_QUERIES=10
GYZA_DEMO_GLOBAL_QUERIES=1000
GYZA_DEMO_GLOBAL_SPEND_USD=5.0
