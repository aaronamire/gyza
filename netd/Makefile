.PHONY: build proto test test-go test-py clean

# Where the protoc-gen-go and protoc-gen-go-grpc plugins live after a
# `go install ...@latest`. Override with `make PROTOC_BIN=...` if your
# layout differs.
PROTOC_BIN ?= $(HOME)/go/bin

build:
	mkdir -p bin
	go build -o bin/gyza-netd ./cmd/gyza-netd/

proto:
	PATH="$(PATH):$(PROTOC_BIN)" protoc \
	    --proto_path=internal/grpc/proto \
	    --go_out=internal/grpc/proto --go_opt=paths=source_relative \
	    --go-grpc_out=internal/grpc/proto --go-grpc_opt=paths=source_relative \
	    internal/grpc/proto/netd.proto
	@# Mirror the .proto into the Python side so `python -m grpc_tools.protoc`
	@# can read it from one canonical location. The Python stubs are
	@# generated by the corresponding rule in ../Makefile.python (or
	@# directly via the proto-py target below if you have grpcio-tools
	@# installed).

proto-py:
	cd .. && python -m grpc_tools.protoc \
	    -I netd/internal/grpc/proto \
	    --python_out=gyza/network/proto \
	    --grpc_python_out=gyza/network/proto \
	    netd/internal/grpc/proto/netd.proto
	@# grpc_tools writes `import netd_pb2 ...` as an absolute import,
	@# which breaks when the package is loaded as gyza.network.proto.
	@# Convert to a relative import so the package works in both
	@# `python -m gyza.cli` and `pytest` invocations.
	sed -i 's/^import netd_pb2 /from . import netd_pb2 /' \
	    ../gyza/network/proto/netd_pb2_grpc.py

test: test-go

test-go:
	go test ./...

clean:
	rm -f bin/gyza-netd
